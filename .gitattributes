# Normalize all text files to LF in the repo (prevents CRLF sneaking in on
# Windows). Shell scripts MUST be LF or they break inside Linux containers.
* text=auto eol=lf

*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
Dockerfile text eol=lf
