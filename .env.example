# ----------------------------------------------------------------------------
# PolyFlow configuration. Copy to `.env` and adjust. All read-only Polymarket
# endpoints used by PolyFlow require NO API key.
# ----------------------------------------------------------------------------

# --- Core ---
POLYFLOW_ENV=development
POLYFLOW_LOG_LEVEL=INFO

# --- Offline / fixtures mode ---
# When true, PolyFlow serves synthetic data from bundled fixtures instead of
# calling the live Polymarket API. Use this to run/test without network access.
POLYFLOW_USE_FIXTURES=true

# When true, the API process also runs the pipeline + price streamer in-process.
# Great for a single-command offline demo (`uvicorn app.main:app`); keep false in
# docker where the dedicated `worker` service handles ingestion + streaming.
POLYFLOW_RUN_WORKER_IN_API=false

# --- Database ---
# Live (docker-compose default). For local offline runs you can use SQLite:
#   POLYFLOW_DATABASE_URL=sqlite+aiosqlite:///./polyflow.db
POLYFLOW_DATABASE_URL=postgresql+asyncpg://polyflow:polyflow@postgres:5432/polyflow

# --- Redis ---
POLYFLOW_REDIS_URL=redis://redis:6379/0

# --- Polymarket endpoints (override only if they change) ---
POLYFLOW_GAMMA_URL=https://gamma-api.polymarket.com
POLYFLOW_DATA_API_URL=https://data-api.polymarket.com
POLYFLOW_CLOB_URL=https://clob.polymarket.com
POLYFLOW_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Pipeline tuning ---
POLYFLOW_MARKET_LIMIT=500          # active markets to track
POLYFLOW_TOP_TRADERS=1000          # traders to score
POLYFLOW_HOLDERS_PER_MARKET=50     # holders sampled per market for discovery
POLYFLOW_HTTP_CONCURRENCY=8        # max concurrent outbound requests
POLYFLOW_SYNC_MARKETS_MINUTES=5
POLYFLOW_SYNC_TRADES_MINUTES=2
POLYFLOW_SYNC_TRADERS_MINUTES=15
POLYFLOW_SCORING_MINUTES=15

# --- Ranking weights (must sum to ~1.0) ---
POLYFLOW_W_PROFITABILITY=0.35
POLYFLOW_W_CONSISTENCY=0.25
POLYFLOW_W_SIZING=0.15
POLYFLOW_W_RISK_ADJUSTED=0.25

# --- Recommendations ---
POLYFLOW_MIN_CONFIDENCE=0.6        # only surface recs at/above this confidence
POLYFLOW_TOP_TRADERS_FOR_RECS=100  # top-N ranked traders feeding consensus

# --- Backtesting ---
POLYFLOW_BACKTEST_MARKETS=300      # resolved markets in the offline backtest scenario

# ----------------------------------------------------------------------------
# Trading (OPT-IN, DISABLED BY DEFAULT).
# Analytics is fully read-only. Order execution only runs when explicitly turned
# on. Keep TRADING_MODE=paper to record intended orders WITHOUT sending them.
# Set TRADING_MODE=live ONLY with real credentials and at your own risk.
# NEVER commit real keys — keep them in your local .env only.
# ----------------------------------------------------------------------------
POLYFLOW_TRADING_ENABLED=false
POLYFLOW_TRADING_MODE=paper        # paper | live
POLYFLOW_TRADING_MIN_CONFIDENCE=0.75
POLYFLOW_TRADING_MAX_ORDER_USD=50
POLYFLOW_TRADING_MAX_DAILY_USD=500
POLYFLOW_TRADING_MAX_OPEN_POSITIONS=20

# Live-only credentials (leave blank for paper mode):
POLYFLOW_POLYGON_PRIVATE_KEY=
POLYFLOW_CLOB_API_KEY=
POLYFLOW_CLOB_API_SECRET=
POLYFLOW_CLOB_API_PASSPHRASE=
